<style data-mw-deduplicate="TemplateStyles:r15968835">.mw-parser-output .ws-poem{display:table;margin:0 auto;max-width:100%}.mw-parser-output .ws-poem-fl,.mw-parser-output .ws-poem-fn{margin-left:0;vertical-align:top}.mw-parser-output .ws-poem-fr{margin-left:auto;margin-right:0;vertical-align:top}.mw-parser-output .ws-poem-stanza{page-break-inside:avoid;break-inside:avoid}.mw-parser-output .ws-poem-stanza.ws-poem-left{display:table;margin-right:auto}.mw-parser-output .ws-poem-stanza.ws-poem-right{display:table;margin-left:auto}.mw-parser-output .ws-poem-stanza.ws-poem-center,.mw-parser-output .ws-poem-cblock{display:table;margin:0 auto}.mw-parser-output .ws-poem-line{display:block;position:relative}.mw-parser-output .ws-poem-hi .ws-poem-line{text-indent:-4em;margin-left:4em}.mw-parser-output .ws-poem-break{position:absolute}.mw-parser-output .ws-poem-line.ws-poem-right{text-align:right}.mw-parser-output .ws-poem-hi .ws-poem-line.ws-poem-right{text-indent:0}.mw-parser-output .ws-poem-line.ws-poem-center{text-align:center}.mw-parser-output .ws-poem-hi .ws-poem-line.ws-poem-center{text-indent:0;margin-left:0}.mw-parser-output .ws-poem-linenum{float:right;text-indent:0;user-select:none}.mw-parser-output .ws-poem-right-gutter .ws-poem-line{padding-right:2em}.mw-parser-output .ws-poem-versenum{float:left;text-indent:0;user-select:none}.mw-parser-output .ws-poem-left-gutter .ws-poem-line{padding-left:2em}.mw-parser-output .ws-poem-stanza:not(:last-child){margin-bottom:1em}.mw-parser-output .ws-poem-indent{display:inline-block;text-indent:0;line-height:0;overflow:hidden}.mw-parser-output .ws-poem-relative-indent{visibility:hidden}.mw-parser-output .ws-poem .wst-fqm{position:absolute}.mw-parser-output .ws-poem-hi .dropinitial{margin-left:-4em}.mw-parser-output .ws-poem-hi .dropinitial-mid{margin-right:4em}.mw-parser-output .ws-poem .pagenum{float:left}.mw-parser-output .ws-poem-blackletter,.mw-parser-output .ws-poem-fractur{font-family:UnifrakturMaguntia,UnifrakturCook,Unifraktur,serif;font-size:113%;font-feature-settings:"cv01","cv02","cv03","cv04","cv05","cv06","cv07","cv08","cv09","cv10"}.mw-parser-output .ws-poem-bl-ls{font-family:UnifrakturMaguntia,UnifrakturCook,Unifraktur,serif;font-size:113%;font-feature-settings:"cv11","cv01","cv02","cv03","cv04","cv05","cv06","cv07","cv08","cv09","cv10"}.mw-parser-output .ws-poem-cursive,.mw-parser-output .ws-poem-handwriting{font-family:Petit Formal Script,cursive}.mw-parser-output .ws-poem-italic,.mw-parser-output .ws-poem.italic,.mw-parser-output .ws-poem-it{font-style:italic}.mw-parser-output .ws-poem-noitalics,.mw-parser-output .ws-poem-ni,.mw-parser-output .ws-poem-fsn{font-style:normal}.mw-parser-output .ws-poem-bold,.mw-parser-output .ws-poem-bb{font-weight:bold}.mw-parser-output .ws-poem-nobold,.mw-parser-output .ws-poem-nb,.mw-parser-output .ws-poem-fwn{font-weight:normal}.mw-parser-output .ws-poem-smallcaps,.mw-parser-output .ws-poem-sc,.mw-parser-output .ws-poem.smallcaps,.mw-parser-output .ws-poem.sc{font-variant:small-caps}.mw-parser-output .ws-poem-asc{font-variant:all-small-caps}.mw-parser-output .ws-poem-fvn{font-variant:normal}.mw-parser-output .ws-poem-xxsmaller,.mw-parser-output .ws-poem-xxs{font-size:58%;line-height:1.4}.mw-parser-output .ws-poem-x-smaller,.mw-parser-output .ws-poem-xs{font-size:69%;line-height:1.4}.mw-parser-output .ws-poem-smaller,.mw-parser-output .ws-poem-sm{font-size:83%;line-height:1.4}.mw-parser-output .ws-poem-fine{font-size:92%;line-height:1.4}.mw-parser-output .ws-poem-larger,.mw-parser-output .ws-poem-lg{font-size:120%;line-height:1.4}.mw-parser-output .ws-poem-x-larger,.mw-parser-output .ws-poem-xl{font-size:144%;line-height:1.4}.mw-parser-output .ws-poem-xx-larger,.mw-parser-output .ws-poem-xxl{font-size:182%;line-height:1.4}.mw-parser-output .ws-poem-xxx-larger,.mw-parser-output .ws-poem-xxxl{font-size:207%;line-height:1.4}.mw-parser-output .ws-poem-xxxx-larger,.mw-parser-output .ws-poem-xxxxl{font-size:249%;line-height:1.4}.mw-parser-output .ws-poem-center,.mw-parser-output .ws-poem-c{text-align:center}.mw-parser-output .ws-poem-speech-prefix-xsmaller .ws-poem-line,.mw-parser-output .ws-poem-speech-prefix-xs .ws-poem-line{margin-left:10em}.mw-parser-output .ws-poem-speech-prefix-smaller .ws-poem-line{margin-left:3em}.mw-parser-output .ws-poem-speech-prefix .ws-poem-line{margin-left:5em}.mw-parser-output .ws-poem-speech-prefix-larger .ws-poem-line{margin-left:7em}.mw-parser-output .ws-poem-speech-prefix-xlarger .ws-poem-line,.mw-parser-output .ws-poem-speech-prefix-xl .ws-poem-line{margin-left:10em}</style><div class="ws-poem ws-poem-hi"><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-line"><span class="smallcaps" style="font-variant:small-caps;">Twinkle</span>, twinkle, little star!<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">How I wonder what you are,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Up above the world so high,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Like a diamond in the sky.<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-line">When the glorious sun is set,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">When the grass with dew is wet,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Then you show your little light,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Twinkle, twinkle all the night.<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-line">In the dark-blue sky you keep,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">And often through my curtains peep,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">For you never shut your eye,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Till the sun is in the sky.<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-line">As your bright and tiny spark<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Guides the traveller in the dark,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Though I know not what you are,<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">Twinkle, twinkle, little star!<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div></div>
<p>&#32;
</p>
</div>
