mon-man/?fo=json"}, {"content": "articles-and-essays/god-bless-america.html", "description": ["The story behind the song \"God Bless America\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/god-bless-america/", "slug": "god-bless-america", "title": "God Bless America", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/god-bless-america/?fo=json"}, {"content": "articles-and-essays/hail-columbia.html", "description": ["The story behind the song \"Hail Columbia\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/hail-columbia/", "slug": "hail-columbia", "title": "Hail Columbia", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/hail-columbia/?fo=json"}, {"content": "articles-and-essays/hail-to-the-chief.html", "description": ["The story behind the song \"Hail to the Chief\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/hail-to-the-chief/", "slug": "hail-to-the-chief", "title": "Hail to the Chief", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/hail-to-the-chief/?fo=json"}, {"content": "articles-and-essays/ill-be-home-for-christmas.html", "description": ["The story behind the song \"I'll Be Home for Christmas\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/ill-be-home-for-christmas/", "slug": "ill-be-home-for-christmas", "title": "I'll Be Home for Christmas", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/ill-be-home-for-christmas/?fo=json"}, {"content": "articles-and-essays/library-of-congress-march.html", "description": ["The story behind the song \"Library of Congress March\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/library-of-congress-march/", "slug": "library-of-congress-march", "title": "Library of Congress March", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/library-of-congress-march/?fo=json"}, {"content": "articles-and-essays/marines-hymn.html", "description": ["The story behind the song \"Marines' Hymn\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/marines-hymn/", "slug": "marines-hymn", "title": "Marines' Hymn", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/marines-hymn/?fo=json"}, {"content": "articles-and-essays/my-country-tis-of-thee.html", "description": ["The story behind the song \"My Country 'Tis of Thee\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/my-country-tis-of-thee/", "slug": "my-country-tis-of-thee", "title": "My Country 'Tis of Thee", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/my-country-tis-of-thee/?fo=json"}, {"content": "articles-and-essays/of-thee-i-sing.html", "description": ["The story behind the song \"Of Thee I Sing\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/of-thee-i-sing/", "slug": "of-thee-i-sing", "title": "Of Thee I Sing", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/of-thee-i-sing/?fo=json"}, {"content": "articles-and-essays/over-there.html", "description": ["The story behind the song \"Over There\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/over-there/", "slug": "over-there", "title": "Over There", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/over-there/?fo=json"}, {"content": "articles-and-essays/semper-paratus.html", "description": ["The story behind the song \"Semper Paratus\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/semper-paratus/", "slug": "semper-paratus", "title": "Semper Paratus", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/semper-paratus/?fo=json"}, {"content": "articles-and-essays/star-spangled-banner.html", "description": ["The story behind the song \"Star Spangled Banner\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/star-spangled-banner/", "slug": "star-spangled-banner", "title": "Star Spangled Banner", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/star-spangled-banner/?fo=json"}, {"content": "articles-and-essays/stars-and-stripes-forever.html", "description": ["The story behind the song \"Stars and Stripes Forever\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/stars-and-stripes-forever/", "slug": "stars-and-stripes-forever", "title": "Stars and Stripes Forever", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/stars-and-stripes-forever/?fo=json"}, {"content": "articles-and-essays/this-land-is-your-land.html", "description": ["The story behind the song \"This Land is Your Land\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/this-land-is-your-land/", "slug": "this-land-is-your-land", "title": "This Land is Your Land", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/this-land-is-your-land/?fo=json"}, {"content": "articles-and-essays/this-is-my-country.html", "description": ["The story behind the song \"This is My Country\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/this-is-my-country/", "slug": "this-is-my-country", "title": "This is My Country", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/this-is-my-country/?fo=json"}, {"content": "articles-and-essays/us-air-force-song.html", "description": ["The story behind the song \"U.S. Air Force Song\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/us-air-force-song/", "slug": "us-air-force-song", "title": "U.S. Air Force Song", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/us-air-force-song/?fo=json"}, {"content": "articles-and-essays/when-johnny-comes-marching-home-again.html", "description": ["The story behind the song \"When Johnny Comes Marching Home Again\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/when-johnny-comes-marching-home-again/", "slug": "when-johnny-comes-marching-home-again", "title": "When Johnny Comes Marching Home Again", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/when-johnny-comes-marching-home-again/?fo=json"}, {"content": "articles-and-essays/yankee-doodle.html", "description": ["The story behind the song \"Yankee Doodle\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/yankee-doodle/", "slug": "yankee-doodle", "title": "Yankee Doodle", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/yankee-doodle/?fo=json"}, {"content": "articles-and-essays/yankee-doodle-boy.html", "description": ["The story behind the song \"The Yankee Doodle Boy\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/yankee-doodle-boy/", "slug": "yankee-doodle-boy", "title": "The Yankee Doodle Boy", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/yankee-doodle-boy/?fo=json"}, {"content": "articles-and-essays/victory-at-sea.html", "description": ["The story behind the song \"Victory at Sea\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/victory-at-sea/", "slug": "victory-at-sea", "title": "Victory at Sea", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/victory-at-sea/?fo=json"}, {"content": "articles-and-essays/youre-a-grand-old-flag.html", "description": ["The story behind the song \"You're a Grand Old Flag\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/youre-a-grand-old-flag/", "slug": "youre-a-grand-old-flag", "title": "You're a Grand Old Flag", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/battle-hymn-of-the-republic/youre-a-grand-old-flag/?fo=json"}], "slug": "articles-and-essays", "title": "Articles & Essays", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/"}], "partof": ["Music Division"], "previous": {"active": false, "content": "articles-and-essays/army-goes-rolling-along.html", "description": ["The story behind the song \"The Army Goes Rolling Along\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/army-goes-rolling-along/", "markup": "<blockquote>\r\n    <p><em>Then it's hi! hi! hee!<br>\r\n      In the field artillery...</em></p>\r\n</blockquote>\r\n    <p>\"The Army Goes Rolling Along\" was designated the official song of the United States Army in 1956. Yet its history goes back to March 1908 when Brigadier General Edmund Louis \"Snitz\" Gruber, a graduate of the United States Military Academy at West Point, wrote \"The Caissons Go Rolling Along.\"</p>\r\n\r\n    <p>Early in his Army career Gruber, a descendent of Franz Gruber, the composer of \"Silent Night,\" was stationed in the Philippines. During a difficult march through the Zambales Mountains on Luzon island Gruber went ahead with a small detachment to select the best route for his battalion. He climbed to higher ground to get an overview and to look back down on the marching companies and artillery. As they rattled nearer Gruber heard one of the section chiefs shout out to his drivers, \"Come on! Keep 'em rolling!\"</p>\r\n    <p>Months later, with lyrical assistance from a number of his fellow lieutenants, Gruber came up with a tune that grew from that experience. Gradually, their song became popular throughout the Army's ranks:</p>\r\n<blockquote>\r\n    <p><em>Over hill, over dale<br>\r\n      As we hit the dusty trail,<br>\r\n      And those caissons go rolling along.<br>\r\n      In and out, hear them shout,<br>\r\n      Counter march and right about,<br>\r\n      And those caissons go rolling along.</em></p>\r\n</blockquote>\r\n    <p>Refrain:<br>\r\n<blockquote>\r\n      <em>Then it's hi! hi! hee!<br>\r\n        In the field artillery,<br>\r\n        Shout out your numbers loud and strong,<br>\r\n        For where e'er you go,<br>\r\n        You will always know<br>\r\n        That those caissons go rolling along.</em></p>\r\n</blockquote>\r\n    <p>Caissons, ammunition containers, were familiar to armies since at least the first years of the eighteenth century. During the Civil War their jolting clatter was described by Horatio Nelson Taft in a manner similar to Gruber's:</p>\r\n    <blockquote>\r\n        <p>There comes down the Avenue a Battery of Artillery. It is astonishing how a Battery of six guns (\"twelve pounders\") will stretch out, and what a rattling it will make over the pavement. Every gun has six horses and a Caisson with six more horses with nine or ten men to a gun. Every gun an[d] Caisson has a spare wheel securely lashed on behind. Then there follows the Am[m]unition wagons and the Forge, and the Baggage. Altogether not less than a quarter of a mile is occupied, perhaps more. Sometimes they go through the Street on a gallop and then such a rumbling and rattling of the carriages and clattering of hoofs of the horses, such a jolting and bounding of the men was never heard or seen.</p>\r\n     <p>\r\n      Diary Entry by Horatio Nelson Taft, December 14, 1864, The Diary of Horatio Nelson Taft, 1861-1865.</p>\r\n</blockquote>\r\n\r\n    <figure class=\"image-align-right\"><a href=\"/resource/fsa.8e01223/\"><img src=\"https://tile.loc.gov/storage-services/service/pnp/fsa/8e01000/8e01200/8e01223r.jpg\" alt=\"Bantam car in air\" width=\"500\" /></a>\u00a0\r\n    <figcaption><a href=\"/item/2017872191/\">Bantam car in mid-air</a>. New River, North Carolina, U.S. Army Signal Corps, photographer, 1941?\u00a0<a href=\"https://www.loc.gov/rr/print/\">Prints and Photographs Division</a>, Library of Congress.</figcaption></figure>\r\n    <p>After World War II, in 1948 and again in 1952, the U.S. Army conducted a nationwide song contest to find an official song. None of the songs submitted proved to be especially popular within the ranks. Finally the Army's major commanders were polled and an overwhelming majority voted for Gruber's \"Caisson song.\" Still, the Army was unwilling to settle for the popular lyrics so it sent out a call for new ones. Of the 140 sets of lyrics received, the screening committee selected phrases from which Dr. H. W. Arberg molded an official song. Although most folks sing the old words, the official first verse now reads:</p>\r\n<blockquote>\r\n    <p><em>March along, sing our song,<br>\r\n      With the Army of the free<br>\r\n      Count the brave, count the true,<br>\r\n      Who have fought to victory<br>\r\n      We're the Army and proud of our name<br>\r\n      We're the Army and proudly proclaim</em></p>\r\n    </blockquote>\r\n    <p>Refrain:<br>\r\n    <blockquote>\r\n      <em>Then it's Hi! Hi! Hey!<br>\r\n        The Army's on its way.<br>\r\n        Count off the cadence loud and strong,<br>\r\n        For where e'er we go,<br>\r\n        You will always know<br>\r\n        That The Army Goes Rolling Along.</em></p>\r\n    </blockquote>\r\n    \r\n          <h2>Learn More About It</h2>\r\n           <ul>\r\n            <li><a href=\"/item/today-in-history/june-16/\">Army Corps of Engineers Formed (Today in History: June 16)</a></li>\r\n           </ul>\r\n           <h2>Related Items</h2>\r\n           <ul>\r\n             <li><a href=\"/item/ihas.100010556/\">U.S. Army Ceremonial Band</a></li>\r\n             <li><a href=\"/item/ihas.100010419/\">U.S. Military Academy Band</a></li>\r\n           </ul>\r\n          <h2>Related Web Sites</h2>\r\n      <ul>\r\n            <li><a href=\"http://www.army.mil/\" target=\"_blank\">United States Army <i class=\"icon icon-external-link\"><span>external link</span></i></a>\u00a0<em>(official Web site)</em></li>\r\n            <li><a href=\"http://www.usma.edu/\" target=\"_blank\">West Point: United States Military Academy\u00a0<i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n            <li><a href=\"http://www.bands.army.mil/\" target=\"_blank\">The United States Army Band <i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n           <li><a href=\"https://history.army.mil/\" target=\"_blank\">U.S. Army Military History Institute <i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n            <li><a href=\"https://armyhistory.org/\" target=\"_blank\">The Army Historical Foundation\u00a0<i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n          </ul>\r\n          <h2>Print Bibliography</h2>\r\n       <ol>\r\n            <li>Grant, John, James M. Lynch, and Ronald H. Bailey.\u00a0<strong>West Point: the first 200 years - the companion to the PBS special</strong>. Guilford, Connecticut: Globe Pequot Press, 2002.\u00a0<em>Call number:\u00a0</em>U410 .L1 G73 2002.</li>\r\n            <li>Hogan, David W., Jr.\u00a0<strong>225 years of service: the U.S. Army, 1775-2000</strong>. Washington, D.C.: Center of Military History, United States Army, 2000.\u00a0<em>Call number:\u00a0</em>E181 .H69 2000.</li>\r\n            <li>Remick, Norman Thomas.\u00a0<strong>Mr. Jefferson's academy: the real story behind West Point</strong>. Warren Grove, New Jersey: N. T. Remick, 1999.\u00a0<em>Call number:</em>\u00a0U410 .L1 R45 1999.</li>\r\n            <li>Weigley, Russell F.\u00a0<strong>History of the United States Army</strong>. Bloomington, Indiana: Indiana University Press, 1984.\u00a0<em>Call number:</em>\u00a0UA25 .W35 1984.</li>\r\n          </ol>", "meta_description": "The story behind the song \"The Army Goes Rolling Along\" with references to Library of Congress collections. ", "pagination": "4 of 28", "slug": "army-goes-rolling-along", "title": "The Army Goes Rolling Along", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/army-goes-rolling-along/"}, "previous_sibling": {"active": false, "content": "articles-and-essays/army-goes-rolling-along.html", "description": ["The story behind the song \"The Army Goes Rolling Along\" with references to Library of Congress collections.\n"], "link": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/army-goes-rolling-along/", "markup": "<blockquote>\r\n    <p><em>Then it's hi! hi! hee!<br>\r\n      In the field artillery...</em></p>\r\n</blockquote>\r\n    <p>\"The Army Goes Rolling Along\" was designated the official song of the United States Army in 1956. Yet its history goes back to March 1908 when Brigadier General Edmund Louis \"Snitz\" Gruber, a graduate of the United States Military Academy at West Point, wrote \"The Caissons Go Rolling Along.\"</p>\r\n\r\n    <p>Early in his Army career Gruber, a descendent of Franz Gruber, the composer of \"Silent Night,\" was stationed in the Philippines. During a difficult march through the Zambales Mountains on Luzon island Gruber went ahead with a small detachment to select the best route for his battalion. He climbed to higher ground to get an overview and to look back down on the marching companies and artillery. As they rattled nearer Gruber heard one of the section chiefs shout out to his drivers, \"Come on! Keep 'em rolling!\"</p>\r\n    <p>Months later, with lyrical assistance from a number of his fellow lieutenants, Gruber came up with a tune that grew from that experience. Gradually, their song became popular throughout the Army's ranks:</p>\r\n<blockquote>\r\n    <p><em>Over hill, over dale<br>\r\n      As we hit the dusty trail,<br>\r\n      And those caissons go rolling along.<br>\r\n      In and out, hear them shout,<br>\r\n      Counter march and right about,<br>\r\n      And those caissons go rolling along.</em></p>\r\n</blockquote>\r\n    <p>Refrain:<br>\r\n<blockquote>\r\n      <em>Then it's hi! hi! hee!<br>\r\n        In the field artillery,<br>\r\n        Shout out your numbers loud and strong,<br>\r\n        For where e'er you go,<br>\r\n        You will always know<br>\r\n        That those caissons go rolling along.</em></p>\r\n</blockquote>\r\n    <p>Caissons, ammunition containers, were familiar to armies since at least the first years of the eighteenth century. During the Civil War their jolting clatter was described by Horatio Nelson Taft in a manner similar to Gruber's:</p>\r\n    <blockquote>\r\n        <p>There comes down the Avenue a Battery of Artillery. It is astonishing how a Battery of six guns (\"twelve pounders\") will stretch out, and what a rattling it will make over the pavement. Every gun has six horses and a Caisson with six more horses with nine or ten men to a gun. Every gun an[d] Caisson has a spare wheel securely lashed on behind. Then there follows the Am[m]unition wagons and the Forge, and the Baggage. Altogether not less than a quarter of a mile is occupied, perhaps more. Sometimes they go through the Street on a gallop and then such a rumbling and rattling of the carriages and clattering of hoofs of the horses, such a jolting and bounding of the men was never heard or seen.</p>\r\n     <p>\r\n      Diary Entry by Horatio Nelson Taft, December 14, 1864, The Diary of Horatio Nelson Taft, 1861-1865.</p>\r\n</blockquote>\r\n\r\n    <figure class=\"image-align-right\"><a href=\"/resource/fsa.8e01223/\"><img src=\"https://tile.loc.gov/storage-services/service/pnp/fsa/8e01000/8e01200/8e01223r.jpg\" alt=\"Bantam car in air\" width=\"500\" /></a>\u00a0\r\n    <figcaption><a href=\"/item/2017872191/\">Bantam car in mid-air</a>. New River, North Carolina, U.S. Army Signal Corps, photographer, 1941?\u00a0<a href=\"https://www.loc.gov/rr/print/\">Prints and Photographs Division</a>, Library of Congress.</figcaption></figure>\r\n    <p>After World War II, in 1948 and again in 1952, the U.S. Army conducted a nationwide song contest to find an official song. None of the songs submitted proved to be especially popular within the ranks. Finally the Army's major commanders were polled and an overwhelming majority voted for Gruber's \"Caisson song.\" Still, the Army was unwilling to settle for the popular lyrics so it sent out a call for new ones. Of the 140 sets of lyrics received, the screening committee selected phrases from which Dr. H. W. Arberg molded an official song. Although most folks sing the old words, the official first verse now reads:</p>\r\n<blockquote>\r\n    <p><em>March along, sing our song,<br>\r\n      With the Army of the free<br>\r\n      Count the brave, count the true,<br>\r\n      Who have fought to victory<br>\r\n      We're the Army and proud of our name<br>\r\n      We're the Army and proudly proclaim</em></p>\r\n    </blockquote>\r\n    <p>Refrain:<br>\r\n    <blockquote>\r\n      <em>Then it's Hi! Hi! Hey!<br>\r\n        The Army's on its way.<br>\r\n        Count off the cadence loud and strong,<br>\r\n        For where e'er we go,<br>\r\n        You will always know<br>\r\n        That The Army Goes Rolling Along.</em></p>\r\n    </blockquote>\r\n    \r\n          <h2>Learn More About It</h2>\r\n           <ul>\r\n            <li><a href=\"/item/today-in-history/june-16/\">Army Corps of Engineers Formed (Today in History: June 16)</a></li>\r\n           </ul>\r\n           <h2>Related Items</h2>\r\n           <ul>\r\n             <li><a href=\"/item/ihas.100010556/\">U.S. Army Ceremonial Band</a></li>\r\n             <li><a href=\"/item/ihas.100010419/\">U.S. Military Academy Band</a></li>\r\n           </ul>\r\n          <h2>Related Web Sites</h2>\r\n      <ul>\r\n            <li><a href=\"http://www.army.mil/\" target=\"_blank\">United States Army <i class=\"icon icon-external-link\"><span>external link</span></i></a>\u00a0<em>(official Web site)</em></li>\r\n            <li><a href=\"http://www.usma.edu/\" target=\"_blank\">West Point: United States Military Academy\u00a0<i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n            <li><a href=\"http://www.bands.army.mil/\" target=\"_blank\">The United States Army Band <i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n           <li><a href=\"https://history.army.mil/\" target=\"_blank\">U.S. Army Military History Institute <i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n            <li><a href=\"https://armyhistory.org/\" target=\"_blank\">The Army Historical Foundation\u00a0<i class=\"icon icon-external-link\"><span>external link</span></i></a></li>\r\n          </ul>\r\n          <h2>Print Bibliography</h2>\r\n       <ol>\r\n            <li>Grant, John, James M. Lynch, and Ronald H. Bailey.\u00a0<strong>West Point: the first 200 years - the companion to the PBS special</strong>. Guilford, Connecticut: Globe Pequot Press, 2002.\u00a0<em>Call number:\u00a0</em>U410 .L1 G73 2002.</li>\r\n            <li>Hogan, David W., Jr.\u00a0<strong>225 years of service: the U.S. Army, 1775-2000</strong>. Washington, D.C.: Center of Military History, United States Army, 2000.\u00a0<em>Call number:\u00a0</em>E181 .H69 2000.</li>\r\n            <li>Remick, Norman Thomas.\u00a0<strong>Mr. Jefferson's academy: the real story behind West Point</strong>. Warren Grove, New Jersey: N. T. Remick, 1999.\u00a0<em>Call number:</em>\u00a0U410 .L1 R45 1999.</li>\r\n            <li>Weigley, Russell F.\u00a0<strong>History of the United States Army</strong>. Bloomington, Indiana: Indiana University Press, 1984.\u00a0<em>Call number:</em>\u00a0UA25 .W35 1984.</li>\r\n          </ol>", "meta_description": "The story behind the song \"The Army Goes Rolling Along\" with references to Library of Congress collections. ", "pagination": "4 of 28", "slug": "army-goes-rolling-along", "title": "The Army Goes Rolling Along", "url": "https://www.loc.gov/collections/patriotic-melodies/articles-and-essays/army-goes-rolling-along/"}, "research-centers": ["performing-arts"], "shards": ["00", "08"], "site_type": "collections", "subjects": ["Arts and Culture", "Music"], "timestamp": 1784184763989, "title": "Patriotic Melodies", "topics": ["Performing Arts", "War & Military", "American History"], "total": 191}