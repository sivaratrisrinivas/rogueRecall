isource.org&amp;utm_campaign=parser&amp;utm_content=thumbnail 2x" data-file-width="410" data-file-height="430" /></a></span></span><a href="/wiki/Portal:Portals" title="Portal:Portals">related portals</a>: <a href="/wiki/Portal:American_literature" title="Portal:American literature">American literature</a></li><li class="sisitem"><span class="sisicon"><span typeof="mw:File/Frameless"><a href="/wiki/Special:SiteMatrix" title="Special:SiteMatrix"><img alt="Sister Projects" src="//upload.wikimedia.org/wikipedia/commons/thumb/8/81/Wikimedia-logo.svg/20px-Wikimedia-logo.svg.png?utm_source=en.wikisource.org&amp;utm_campaign=parser&amp;utm_content=thumbnail" decoding="async" width="18" height="18" class="mw-file-element" srcset="//upload.wikimedia.org/wikipedia/commons/thumb/8/81/Wikimedia-logo.svg/40px-Wikimedia-logo.svg.png?utm_source=en.wikisource.org&amp;utm_campaign=parser&amp;utm_content=thumbnail 2x" data-file-width="1024" data-file-height="1024" /></a></span></span><a href="/wiki/Special:SiteMatrix" title="Special:SiteMatrix">sister projects</a>: <a href="https://en.wikipedia.org/wiki/Moby-Dick" class="extiw" title="w:Moby-Dick">Wikipedia article</a>, <a href="https://commons.wikimedia.org/wiki/Moby-Dick" class="extiw" title="c:Moby-Dick">Commons gallery</a>, <a href="https://commons.wikimedia.org/wiki/Category:Moby_Dick" class="extiw" title="c:Category:Moby Dick">Commons category</a>, <a href="https://en.wikiquote.org/wiki/Moby-Dick" class="extiw" title="q:Moby-Dick">quotes</a>, <a href="https://www.wikidata.org/wiki/Q174596" class="extiw" title="d:Q174596">Wikidata item</a></li></ul><div class="wst-header-content header&#95;notes&#95;content wst-header-notes-content wst-unknown-notes-content">
<p>A novel by American writer Herman Melville. Two very different first editions were published in 1851, one in London and the other in New York. For more details concerning the publication history and differences between the editions, see <a href="https://en.wikipedia.org/wiki/Moby-Dick" class="extiw" title="w:Moby-Dick">Wikipedia</a>.
</p>
</div></div><div class="ws-noexport" id="ws-data" style="speak:none"><span id="ws-article-id">2717887</span><span id="ws-title">Moby-Dick</span><span id="ws-author">Herman Melville</span></div></div>
<div class="subNote" style="margin:4px auto 4px auto;"><span id="nofooter">Versions of <b><i>Moby-Dick</i></b> include:</span></div>
<ul><li><i>Moby-Dick</i>, 1st UK edition (18 Oct 1851)</li>
<li><i><a href="/wiki/Moby-Dick_(1851)_US_edition" title="Moby-Dick (1851) US edition">Moby-Dick</a></i>, 1st US edition (14 Nov 1851)</li></ul>
<div class="mw-heading mw-heading2"><h2 id="Film_adaptations">Film adaptations</h2><span class="mw-editsection"><span class="mw-editsection-bracket">[</span><a href="/w/index.php?title=Moby-Dick_(Melville)&amp;action=edit&amp;section=1" title="Edit section: Film adaptations"><span>edit</span></a><span class="mw-editsection-bracket">]</span></span></div>
<ul><li><i><a href="/wiki/The_Sea_Beast" title="The Sea Beast">The Sea Beast</a></i> (1926), directed by <a href="/wiki/Author:Millard_Webb" title="Author:Millard Webb">Millard Webb</a></li></ul>
<p><br />
</p>
