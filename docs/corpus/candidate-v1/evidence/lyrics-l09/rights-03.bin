        var seeAllButtonWrapper = $('.see-all-comments-button-wrapper');
        var comments = $('.comments-area > ol > li');
        var moreComments = $('.comments-area > ol > li:gt(2)').length > 0;
        if (moreComments) {
            seeAllButtonWrapper.show();
        }
        else {
