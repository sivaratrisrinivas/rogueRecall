            <li id="comment-79026" class="comment even thread-even depth-1"><article id="div-comment-79026" class="comment-body media"><footer class="comment-meta media-left"></footer><!-- .comment-meta -->
    <div class="comment-content media-body">
        <div class="comment-author vcard">
            <div class="comment-metadata">
            <cite class="fn">taylhardat</cite> <span class="says">says:</span>
        </div><!-- .comment-author -->
