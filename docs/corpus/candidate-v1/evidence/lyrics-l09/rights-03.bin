                document.title + ' ' + location.href
            )
        );

        // copy link
        $(".share .share-link-copy-link").on("click", function() {
            var input = document.createElement("input"),
                label = $(this).text().trim();
            document.body.appendChild(input);
            input.value = window.location.href;
            input.select();
            document.execCommand("copy", false);
            $(this).attr('title','This link has been copied to your clipboard').tooltip('dispose').tooltip('show');
            input.remove();
            setTimeout(function(){
                $(".share .share-link-copy-link").tooltip('hide').attr('data-original-title','').attr('title', 'Copy link to clipboard');
            },3000);
        });

        // external links
