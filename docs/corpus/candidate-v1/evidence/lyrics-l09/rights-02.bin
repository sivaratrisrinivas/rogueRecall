    function handleGuideMenuEscapeKey(e) {
        if (e.key !== 'Escape') return;

        const activeEl = document.activeElement;
        if (!activeEl) return;

        const menu = activeEl.closest('.s-lg-subtab-ul.dropdown-menu');
        if (!menu) return;

        e.preventDefault();
        e.stopImmediatePropagation();

        const dropdown = menu.closest('.dropdown');
        if (!dropdown) return;

        const trigger = dropdown.querySelector('.s-lg-tab-drop.dropdown-toggle');
        menu.classList.remove('show');
        if (trigger) {
            trigger.setAttribute('aria-expanded', 'false');
            trigger.focus();
        }
    }

    document.addEventListener('keydown', handleGuideMenuEscapeKey, true);
</script>

