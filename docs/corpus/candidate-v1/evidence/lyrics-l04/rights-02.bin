.322696, "shelf_id": "https://repo.loc.gov/access/public/music/mussm-sm1882-22527/.resource.json", "site": ["catalog"], "timestamp": "2025-06-21T10:03:03.447Z", "title": "In forest green; March", "type": ["notated music"], "url": "https://www.loc.gov/item/2023846338/"}], "options": {"access_group": [""], "access_group_raw": "", "all": null, "api_version": "1", "app_context": null, "application_version": "$Revision$", "attribute": null, "attribute!": null, "attribute_map": null, "cache_tags": ["paprika-music", "catalog-split-00", "catalog", "main-catalog-split-00", "collections-portal", "catalog-split-13", "main-catalog-split-13", "catalog-split-05", "main-catalog-split-05", "catalog-split-14", "main-catalog-split-14", "catalog-split-07", "main-catalog-split-07", "cms", "managed-content"], "callback": null, "clip": null, "clip_image_width": null, "clip_rotation": null, "content_filter": null, "content_replacement": "", "count": null, "dates": null, "default_count": 25, "delimiter": null, "digital_id": null, "display_level": null, "distance": null, "downloadOption": null, "duration": 1.2247612476348877, "embed": [], "embed!": [], "error_response_status": null, "excludeTerms": null, "facetLimits": "", "facetPrefix": null, "facet_count": null, "facet_style": null, "field": null, "format": "json", "host": "www.loc.gov", "ical": false, "id": "2023850903/", "iiif": false, "index": null, "inputEncoding": "UTF-8", "item": null, "items": null, "keys": null, "language": null, "latlong": null, "method": "GET", "newSearch": null, "new_clip_url": false, "onsite": false, "operator": null, "outputEncoding": "UTF-8", "page_campaigns": [], "path_info": "/item/2023850903/", "port": "443", "proxypath": null, "query_string": "fo=json", "redirect_proxy": false, "redirect_to_item": null, "referer": "", "region": "", "release_id": 123456789, "request_host": "www.loc.gov", "request_params": {"fo": ["json"]}, "request_url": "https://www.loc.gov/item/2023850903/?fo=json", "resource": "", "resource_sequence": null, "scheme": "https", "searchIn": null, "searchTerms": "", "segments": null, "shards": ["08"], "site_id": null, "site_type": null, "solrQuery": "", "sortBy": null, "sortOrder": null, "startPage": null, "style": null, "suggested": null, "target": null, "template": "layouts/item/layout", "timestamp": 1784184738.072728, "tz_aware": null, "unionFacets": "", "webcast_permalink": null}, "related_items": [{"access_restricted": false, "aka": ["http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/in-performance-choral-works-from-the-collection/"], "campaigns": [], "date": "1870", "dates": ["[1870 TO 1885]"], "description": ["The following recordings demonstrate a variety of compositions selected from the collection Music For The Nation: American Sheet Music, 1870-1885. All are typical of the four-part choral writing of the period, both for hymns and songs with refrain. These twelve pieces cover a variety of subjects and reveal the musical style within the social and political landscape of that era. They are all linked to their respective bibliographic records and, in most cases, to the Special Presentation \"Music Published in America, 1870-1885.\""], "digitized": true, "extract_timestamp": "2026-07-16T05:17:05.800Z", "group": ["cms", "managed-content"], "hassegments": false, "id": "http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/in-performance-choral-works-from-the-collection/", "image_url": ["https://www.loc.gov/static/collections/american-sheet-music-1870-to-1885/articles-and-essays/in-performance-choral-works-from-the-collection/images/daughter.gif"], "index": 1, "language": ["english"], "location": ["united states"], "mime_type": ["image/jpg"], "online_format": ["image"], "original_format": ["web page"], "partof": ["music for the nation: american sheet music, ca. 1870-1885"], "score": 7.1803713, "shelf_id": "~/collections/american-sheet-music-1870-to-1885/articles-and-essays/in-performance-choral-works-from-the-collection/", "site": ["cms"], "subject": ["hymns", "sheet music", "orchestra music", "songs", "copyright", "choral music", "piano music"], "timestamp": "2026-07-16T06:21:14.002Z", "title": "In Performance: Choral Works from the Collection | Articles and Essays | Music for the Nation: American Sheet Music, ca. 1870 to 1885 | Digital Collections", "type": ["web page"], "url": "https://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/in-performance-choral-works-from-the-collection/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/"], "campaigns": [], "date": "1870", "dates": ["[1870 TO 1885]"], "description": ["Music Published in America, 1870-1885 Introduction to Music Published in America, 1870-1885 In 1870 the Library of Congress became the repository for all music submitted for copyright registration. In the ensuing decade, more than twenty-two"], "digitized": true, "extract_timestamp": "2026-07-16T05:17:05.800Z", "group": ["cms", "managed-content"], "hassegments": false, "id": "http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/", "image_url": ["https://www.loc.gov/static/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/images/carry-me-back.jpg"], "index": 2, "language": ["english"], "location": ["united states"], "mime_type": ["image/jpg"], "online_format": ["image"], "original_format": ["web page"], "partof": ["music for the nation: american sheet music, ca. 1870-1885"], "score": 7.1803713, "shelf_id": "~/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/", "site": ["cms"], "subject": ["hymns", "sheet music", "orchestra music", "songs", "copyright", "choral music", "piano music"], "timestamp": "2026-07-16T06:21:14.002Z", "title": "Music Published in America, 1870 to 1885 | Articles and Essays | Music for the Nation: American Sheet Music, ca. 1870 to 1885 | Digital Collections", "type": ["web page"], "url": "https://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/ethnic-groups-and-popular-songs/"], "campaigns": [], "description": ["Characters from several ethnic groups appear repeatedly in songs of the period. Though they often speak in the first person (\"I'm Terence O'Reilly, I'm a man of renown. . .\"), they are usually seen from outside (though \"Is That Mr. Reilly?\" is in fact by Irish-American comic Pat Rooney). The two groups that appear most often are Irish and Irish Americans (the distinction is not always profitable, especially since many songs concern a sweetheart in Ireland yearning for someone in America or vice versa; they will both be \"Irish\" from here on in this essay) and African Americans. There are few songs about Africans, unless one counts material from such European imports as Supp\u00e9's Afrikareise and Verdi's A\u00efda. Irish songs are more numerous during the 1870s, African-American in the 1880s, but both ethnic groups are regular presences in all years from 1870 to 1885."], "digitized": true, "extract_timestamp": "2026-07-16T05:17:05.800Z", "group": ["cms", "managed-content"], "hassegments": false, "id": "http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/ethnic-groups-and-popular-songs/", "image_url": ["https://www.loc.gov/static/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/images/eilleen-allanna.jpg"], "index": 3, "language": ["english"], "mime_type": ["image/jpg"], "online_format": ["image"], "original_format": ["web page"], "partof": ["music for the nation: american sheet music, ca. 1870-1885"], "score": 7.1803713, "shelf_id": "~/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/ethnic-groups-and-popular-songs/", "site": ["cms"], "timestamp": "2026-07-16T06:21:14.002Z", "title": "Ethnic Groups and Popular Songs | Music Published in America, 1870 to 1885 | Articles and Essays | Music for the Nation: American Sheet Music, ca. 1870 to 1885 | Digital Collections", "type": ["web page"], "url": "https://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/ethnic-groups-and-popular-songs/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/european-music-in-america/"], "campaigns": [], "description": ["Not all the music in this collection was written in the Americas. A good proportion--more than a third, less than a half--was written in Europe by European composers. A very few items are copyright deposits by European publishers, deposited in America to secure American copyright. (Johannes Brahms's publisher was the most careful about this.) There are also a few deposits by Canadian publishers, and a small amount of Mexican music, most of it published in New Orleans. But most of the European music that appears here was published in America by American publishers, encouraged by the lack of copyright agreements with Europe."], "digitized": true, "extract_timestamp": "2026-07-16T05:17:05.800Z", "group": ["cms", "managed-content"], "hassegments": false, "id": "http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/european-music-in-america/", "image_url": ["https://www.loc.gov/static/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/images/hms-pinafore.jpg"], "index": 4, "language": ["english"], "mime_type": ["image/jpg"], "online_format": ["image"], "original_format": ["web page"], "partof": ["music for the nation: american sheet music, ca. 1870-1885"], "score": 7.1803713, "shelf_id": "~/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/european-music-in-america/", "site": ["cms"], "timestamp": "2026-07-16T06:21:14.002Z", "title": "European Music in America | Music Published in America, 1870 to 1885 | Articles and Essays | Music for the Nation: American Sheet Music, ca. 1870 to 1885 | Digital Collections", "type": ["web page"], "url": "https://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/european-music-in-america/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/friends-from-the-stephen-foster-era/"], "campaigns": [], "description": ["Some of Foster's fellow songwriters of the Civil War period were still active: Henry Clay Work (1832-1884), Will S. Hays (1837-1907), and George Frederick Root (1820-1895). Work, with his \"Grandfather's Clock,\"(audio clip) and Hays, with \"The Little Old Cabin in the Lane\" (parodied as the cowboy song \"The Little Old Sod Shanty on My Claim\"), each had one of his most enduring hits in the 1870s."], "digitized": true, "extract_timestamp": "2026-07-16T05:17:05.800Z", "group": ["cms", "managed-content"], "hassegments": false, "id": "http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/friends-from-the-stephen-foster-era/", "image_url": ["https://www.loc.gov/static/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/images/love-lies-dreaming.jpg"], "index": 5, "language": ["english"], "mime_type": ["image/jpg"], "online_format": ["image"], "original_format": ["web page"], "partof": ["music for the nation: american sheet music, ca. 1870-1885"], "score": 7.1803713, "shelf_id": "~/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/friends-from-the-stephen-foster-era/", "site": ["cms"], "timestamp": "2026-07-16T06:21:14.002Z", "title": "Friends from the Stephen Foster Era | Music Published in America, 1870 to 1885 | Articles and Essays | Music for the Nation: American Sheet Music, ca. 1870 to 1885 | Digital Collections", "type": ["web page"], "url": "https://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/friends-from-the-stephen-foster-era/"}, {"access_restricted": false, "aka": ["http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/a-new-generation-of-songwriters/"], "campaigns": [], "description": ["The new songwriter of the period whose songs made the most permanent impact on American music was James M. Bland (1854-1911), the first prominent African-American songwriter, whose \"Carry Me Back to Old Virginny,\" \"In the Evening by the Moonlight,\" and \"Golden Slippers\" are still well known. Other songs of his that were major hits during the period are \"In the Morning by the Bright Light\" and \"De Golden Wedding.\" Bland wrote most of his songs in a burst of activity from 1879 to 1882; in 1881 he left America for England with Haverly's Genuine Colored Minstrels. Bland found England more rewarding than the United States and stayed there until 1890; either he stopped writing songs during this period or he was unable to find an English publisher."], "digitized": true, "extract_timestamp": "2026-07-16T05:17:05.800Z", "group": ["cms", "managed-content"], "hassegments": false, "id": "http://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/a-new-generation-of-songwriters/", "image_url": ["https://www.loc.gov/static/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/images/3-great-songs.jpg"], "index": 6, "language": ["english"], "mime_type": ["image/jpg"], "online_format": ["image"], "original_format": ["web page"], "partof": ["music for the nation: american sheet music, ca. 1870-1885"], "score": 7.1803713, "shelf_id": "~/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/a-new-generation-of-songwriters/", "site": ["cms"], "timestamp": "2026-07-16T06:21:14.002Z", "title": "A New Generation of Songwriters | Music Published in America, 1870 to 1885 | Articles and Essays | Music for the Nation: American Sheet Music, ca. 1870 to 1885 | Digital Collections", "type": ["web page"], "url": "https://www.loc.gov/collections/american-sheet-music-1870-to-1885/articles-and-essays/music-published-in-america-1870-1885/a-new-generation-of-songwriters/"}], "resources": [{"caption": null, "files": [[{"height": "5850", "info": "https://tile.loc.gov/image-services/iiif/public:music:mussm-sm1883-25198:001/info.json", "levels": "6", "mimetype": "image/jp2", "other_name": "001.jp2", "size": 1372929, "url": "https://tile.loc.gov/storage-services/public/music/mussm-sm1883-25198/001.jp2", "width": "4730"}, {"height": 5850, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/public:music:mussm-sm1883-25198:001/full/pct:100.0/0/default.jpg", "width": 4730}, {"height": 2925, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/public:music:mussm-sm1883-25198:001/full/pct:50.0/0/default.jpg", "width": 2365}, {"height": 1462, "levels": 1, "mimetype": "image/jpeg", "url": "https://tile.loc.gov/image-services/iiif/public:music:mussm-sm1883-25198:001/full/pct:25.0/0/default.jpg", "width": 1182}, {"height": 731, "levels": 1, "mimetype": "image/