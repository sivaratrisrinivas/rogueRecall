aktur,serif;font-size:113%;font-feature-settings:"cv01","cv02","cv03","cv04","cv05","cv06","cv07","cv08","cv09","cv10"}.mw-parser-output .ws-poem-bl-ls{font-family:UnifrakturMaguntia,UnifrakturCook,Unifraktur,serif;font-size:113%;font-feature-settings:"cv11","cv01","cv02","cv03","cv04","cv05","cv06","cv07","cv08","cv09","cv10"}.mw-parser-output .ws-poem-cursive,.mw-parser-output .ws-poem-handwriting{font-family:Petit Formal Script,cursive}.mw-parser-output .ws-poem-italic,.mw-parser-output .ws-poem.italic,.mw-parser-output .ws-poem-it{font-style:italic}.mw-parser-output .ws-poem-noitalics,.mw-parser-output .ws-poem-ni,.mw-parser-output .ws-poem-fsn{font-style:normal}.mw-parser-output .ws-poem-bold,.mw-parser-output .ws-poem-bb{font-weight:bold}.mw-parser-output .ws-poem-nobold,.mw-parser-output .ws-poem-nb,.mw-parser-output .ws-poem-fwn{font-weight:normal}.mw-parser-output .ws-poem-smallcaps,.mw-parser-output .ws-poem-sc,.mw-parser-output .ws-poem.smallcaps,.mw-parser-output .ws-poem.sc{font-variant:small-caps}.mw-parser-output .ws-poem-asc{font-variant:all-small-caps}.mw-parser-output .ws-poem-fvn{font-variant:normal}.mw-parser-output .ws-poem-xxsmaller,.mw-parser-output .ws-poem-xxs{font-size:58%;line-height:1.4}.mw-parser-output .ws-poem-x-smaller,.mw-parser-output .ws-poem-xs{font-size:69%;line-height:1.4}.mw-parser-output .ws-poem-smaller,.mw-parser-output .ws-poem-sm{font-size:83%;line-height:1.4}.mw-parser-output .ws-poem-fine{font-size:92%;line-height:1.4}.mw-parser-output .ws-poem-larger,.mw-parser-output .ws-poem-lg{font-size:120%;line-height:1.4}.mw-parser-output .ws-poem-x-larger,.mw-parser-output .ws-poem-xl{font-size:144%;line-height:1.4}.mw-parser-output .ws-poem-xx-larger,.mw-parser-output .ws-poem-xxl{font-size:182%;line-height:1.4}.mw-parser-output .ws-poem-xxx-larger,.mw-parser-output .ws-poem-xxxl{font-size:207%;line-height:1.4}.mw-parser-output .ws-poem-xxxx-larger,.mw-parser-output .ws-poem-xxxxl{font-size:249%;line-height:1.4}.mw-parser-output .ws-poem-center,.mw-parser-output .ws-poem-c{text-align:center}.mw-parser-output .ws-poem-speech-prefix-xsmaller .ws-poem-line,.mw-parser-output .ws-poem-speech-prefix-xs .ws-poem-line{margin-left:10em}.mw-parser-output .ws-poem-speech-prefix-smaller .ws-poem-line{margin-left:3em}.mw-parser-output .ws-poem-speech-prefix .ws-poem-line{margin-left:5em}.mw-parser-output .ws-poem-speech-prefix-larger .ws-poem-line{margin-left:7em}.mw-parser-output .ws-poem-speech-prefix-xlarger .ws-poem-line,.mw-parser-output .ws-poem-speech-prefix-xl .ws-poem-line{margin-left:10em}</style><div class="ws-poem ws-poem-hi ws-poem-left-gutter"><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-versenum">1 </span><span class="ws-poem-line"><span class="smallcaps" style="font-variant:small-caps;">Amazing</span> grace! (how sweet the sound!) <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>That saved a wretch like me! <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">I once was lost, but now am found,—<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>Was blind, but now I see. <span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-versenum">2 </span><span class="ws-poem-line">'Twas grace that taught my heart to fear, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>And grace my fears relieved; <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">How precious did that grace appear<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>The hour I first believed!<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div>&#32;<span><span class="pagenum ws-pagenum" id="96" data-page-number="96" data-page-name="Page:Olney Hymns - 1840.djvu/100" data-page-index="100" data-page-quality="4" title="Page:Olney&#95;Hymns&#95;-&#95;1840.djvu/100"><span id="pageindex&#95;100" class="pagenum-inner ws-noexport">&#8203;</span></span></span><link rel="mw-deduplicated-inline-style" href="mw-data:TemplateStyles:r15968835" /><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-versenum">3 </span><span class="ws-poem-line">Through many dangers, toils, and snares. <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>I have already come; <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">'Tis grace has brought me safe thus far, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>And grace will lead me home.<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-versenum">4 </span><span class="ws-poem-line">The Lord has promised good to me,—<span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>His word my hope secures; <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">He will my shield and portion be <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>As long as life endures. <span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-versenum">5 </span><span class="ws-poem-line">Yes, when this flesh and heart shall fail, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>And mortal life shall cease, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">I shall possess, within the veil, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>A life of joy and peace. <span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div><div class="ws-poem-stanza" role="paragraph"><span class="ws-poem-versenum">6 </span><span class="ws-poem-line">The earth shall soon dissolve like snow, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>The sun forbear to shine; <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line">But God, who call'd me here below, <span class="ws-poem-break"><br /></span></span><span class="ws-poem-line"><span class="wst-gap &#95;&#95;gap" style="display:inline-block; inline-size:1em"></span>Will be for ever mine.<span class="ws-poem-break"><br /></span></span><span class="ws-poem-break"><br /></span></div></div>
<p>&#32;
</p>
</div>
