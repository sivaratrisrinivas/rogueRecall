ginally issued as \"The Great Gospel Voice of Marion Williams\" on Epic BN 26175 in 1965", "Originally issued on Epic BN 26175", "Originally issued in 1965", "Courtesy of Sony BMG Music Entertainment, www.sonybmg.com."], "repository": "motion picture, broadcasting and recorded sound division", "rights": "No known restrictions on use or reproduction.", "source_collection": "Amazing Grace", "subjects": ["Songs and Music", "Songs and music"], "title": "Amazing grace"}, "language": ["english"], "mime_type": ["audio/mpeg", "image/jpeg", "application/pdf", "image/jp2"], "number": ["ihas.200149082", "http://www.loc.gov/resource/ihas.200149082.0"], "number_dmtoolid": ["ihas.200149082"], "number_former_id": ["http://www.loc.gov/resource/ihas.200149082.0"], "online_format": ["audio", "image", "pdf"], "original_format": ["sound recording"], "partof": ["national audiovisual conservation center", "amazing grace", "the library of congress celebrates the songs of america"], "resources": [{"audio": "https://tile.loc.gov/storage-services/public/navcc/ihas-200149082/ihas-200149082.mp3", "caption": "Amazing grace", "files": 1, "former_urls": 1, "paprika_resource_path": "/sets/navcc/ihas-200149082", "schemaVersion": "v1", "url": "https://www.loc.gov/resource/navcc.ihas-200149082/", "version": 4}, {"caption": "Amazing grace", "files": 1, "image": "https://tile.loc.gov/image-services/iiif/public:navcc:ihas-200149082-image:ihas-200149082/full/pct:25.0/0/default.jpg", "paprika_resource_path": "/sets/navcc/ihas-200149082-image", "pdf": "https://tile.loc.gov/storage-services/public/navcc/ihas-200149082-image/ihas-200149082-image.pdf", "schemaVersion": "v1", "url": "https://www.loc.gov/resource/navcc.ihas-200149082-image/", "version": 4}], "shelf_id": "LC Classification: SDB 06384", "subject": ["songs and music"], "timestamp": "2025-09-18T07:55:41.015Z", "title": "Amazing grace", "type": ["sound recording-musical"], "url": "https://www.loc.gov/item/ihas.200149082/"}, {"access_restricted": fal