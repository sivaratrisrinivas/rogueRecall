<li><style data-mw-deduplicate="TemplateStyles:r15851853">.mw-parser-output .wst-artlink-periodical{font-style:italic}.mw-parser-output .wst-artlink-volnum{font-weight:bold}</style><span class="wst-artlink">"<a href="/wiki/The_Atlantic_Monthly/Volume_18/Number_110/Reconstruction" title="The Atlantic Monthly/Volume 18/Number 110/Reconstruction">Reconstruction</a>" in <cite class="wst-artlink-periodical"><a href="/wiki/The_Atlantic_Monthly" title="The Atlantic Monthly">The Atlantic Monthly</a></cite>, <span class="wst-artlink-midlevel wst-artlink-volnum"><a href="/wiki/The_Atlantic_Monthly/Volume_18" title="The Atlantic Monthly/Volume 18">18</a></span> (<span class="wst-artlink-midlevel wst-artlink-issnum"><a href="/wiki/The_Atlantic_Monthly/Volume_18/Number_110" title="The Atlantic Monthly/Volume 18/Number 110">110</a></span>) (<span class="wst-artlink-date">December, 1866</span>)</span>.</li>
<li><link rel="mw-deduplicated-inline-style" href="mw-data:TemplateStyles:r15851853" /><span class="wst-artlink">"<a href="/wiki/The_Atlantic_Monthly/Volume_19/Number_111/An_Appeal_to_Congress_for_Impartial_Suffrage" title="The Atlantic Monthly/Volume 19/Number 111/An Appeal to Congress for Impartial Suffrage">An Appeal to Congress for Impartial Suffrage</a>" in <cite class="wst-artlink-periodical"><a href="/wiki/The_Atlantic_Monthly" title="The Atlantic Monthly">The Atlantic Monthly</a></cite>, <span class="wst-artlink-midlevel wst-artlink-volnum"><a href="/wiki/The_Atlantic_Monthly/Volume_19" title="The Atlantic Monthly/Volume 19">19</a></span> (<span class="wst-artlink-midlevel wst-artlink-issnum"><a href="/wiki/The_Atlantic_Monthly/Volume_19/Number_111" title="The Atlantic Monthly/Volume 19/Number 111">111</a></span>) (<span class="wst-artlink-date">January, 1867</span>)</span></li>
